# MiroFootball 环境变量模板(plan 03§8)。复制为 .env(已 gitignore)。真实密钥绝不入库。
# ── 三模型端点(铁律: :11434/:11435 共享只读, 绝不重启/改 num_ctx) ──
BRAIN_URL=http://localhost:11434          # 共享 nemotron(持球/防守决策), 只读
GEMMA_HOME_URL=http://localhost:11436     # 自有 home gemma 实例(无球摆位)
GEMMA_AWAY_URL=http://localhost:11437     # 自有 away gemma 实例
BRAIN_MODEL=nemotron-3-super:120b
GEMMA_MODEL=gemma4:e2b-it-qat             # 底座; LoRA 经 gemma-<team> 覆盖
ENGINE_URL=http://localhost:7000          # node 足球引擎(被驱动的 env)

# ── 摆位模式 ──
MIRO_INTENT=1                             # 1=C(60%引擎+40%LLM intentTarget 混合) / 0=B(纯引擎摆位)

# ── KG(可选, 连不上则优雅 no-op) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── 数据接入(API-Football; 真实 key 放 .env, 勿入库) ──
API_FOOTBALL_KEY=your_key_here

# ── 双机(ConnectX 直连; Box B 训练) ──
BOX_B_HOST=<box-b-ip-or-host>
BOX_B_USER=<box-b-username>
BOX_B_SSH_KEY=~/.ssh/<your-ssh-key>
